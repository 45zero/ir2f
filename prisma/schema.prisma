// IR2F — Plateforme de formation LGEF
// Schema dédié "ir2f", isolé de public/auth

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ir2f"]
}

// ─── ENUMS ───────────────────────────────────────────

enum Role {
  STAGIAIRE
  FORMATEUR
  ADMIN
  DIRECTION

  @@schema("ir2f")
}

enum StatutInscription {
  EN_ATTENTE
  VALIDEE
  REFUSEE

  @@schema("ir2f")
}

enum TypeFormation {
  PRESENTIEL
  VISIO
  ELEARNING
  MIXTE

  @@schema("ir2f")
}

enum StatutFormation {
  BROUILLON
  PUBLIEE
  ARCHIVEE

  @@schema("ir2f")
}

enum CategorieFormation {
  EDUCATEUR
  ARBITRAGE
  TERRAIN
  CLUB
  DEV

  @@schema("ir2f")
}

enum Filiere {
  PROFESSIONNELLE
  BENEVOLE

  @@schema("ir2f")
}

// Groupe d'appartenance dans le diagramme "équivalences et passerelles"
// (page /formations, onglet Éducateur). Null = formation hors diagramme.
enum GroupeEquivalence {
  AF
  CFI
  DF
  CERTIF
  PRO_TOP
  PRO_MID
  PRO_BEF
  PRO_BMF
  PRO_MID2
  PRO_BOTTOM

  @@schema("ir2f")
}

enum VarianteNode {
  NAVY
  LIGHT
  RED
  OUTLINE

  @@schema("ir2f")
}

enum DocumentCategorie {
  ADMINISTRATIF
  PEDAGOGIQUE

  @@schema("ir2f")
}

enum StatutCovoiturage {
  OUVERT
  COMPLET
  ANNULE

  @@schema("ir2f")
}

// Mode d'inscription à une formation : formulaire interne IR2F, ou
// redirection vers le portail d'inscription de la FFF (IR2F gère alors
// uniquement les documents internes — convention de stage, etc.)
enum ModeInscription {
  INTERNE
  PORTAIL_FFF

  @@schema("ir2f")
}

// Origine d'une inscription — permet de distinguer les inscriptions
// enregistrées en interne de celles capturées avant redirection vers la FFF
enum OrigineInscription {
  INTERNE
  FFF_STAGIAIRE
  FFF_CLUB

  @@schema("ir2f")
}

// Type de lien pour les boutons configurables de l'accueil (bandeau emploi)
enum TypeLien {
  INTERNE
  EXTERNE

  @@schema("ir2f")
}

// ─── UTILISATEURS ────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nom       String
  prenom    String
  telephone String?
  password  String?
  role      Role     @default(STAGIAIRE)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inscriptions         Inscription[]
  documentsUpload      Document[]
  signatures           Signature[]
  messagesEnvoyes      Message[]             @relation("Expediteur")
  messagesRecus        MessageDestinataire[]
  covoituragesConduit  Covoiturage[]         @relation("Conducteur")
  covoituragesPassager CovoituragePassager[]
  articles             Article[]
  demandesInscription  DemandeInscription[]
  formationsEnCharge   FormationFormateur[]

  @@schema("ir2f")
}

// ─── FORMATIONS ──────────────────────────────────────

model Formation {
  id            String          @id @default(uuid())
  slug          String          @unique
  titre         String
  description   String?
  type          TypeFormation
  statut        StatutFormation @default(BROUILLON)
  dureeHeures   Int?
  dureeLabel    String?
  modeLabel     String?
  lieu          String?
  prix          Float?
  places        Int?
  lienVisio     String?
  image         String?
  programme     Json?
  formateurNom  String?
  formateurRole String?
  ordre         Int             @default(0)

  categorie   CategorieFormation @default(EDUCATEUR)
  filiere     Filiere?
  cpfEligible Boolean            @default(false)

  // Inscription via le portail FFF (externe à IR2F) — lien distinct selon
  // que ce soit le stagiaire ou le club qui réalise l'inscription
  modeInscription   ModeInscription @default(INTERNE)
  lienFffStagiaire  String?
  lienFffClub       String?

  // Diagramme "équivalences et passerelles" — null si hors diagramme
  groupeEquivalence GroupeEquivalence?
  varianteNode      VarianteNode?
  badgeNode         String?
  shortNode         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions     Session[]
  inscriptions Inscription[]
  demandes     DemandeInscription[]
  documents    Document[]
  heroSlides   HeroSlide[]
  formateurs   FormationFormateur[]
  messages     Message[]
  covoiturages Covoiturage[]

  @@schema("ir2f")
}

model FormationFormateur {
  id          String   @id @default(uuid())
  userId      String
  formationId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  formation Formation @relation(fields: [formationId], references: [id])

  @@unique([userId, formationId])
  @@schema("ir2f")
}

model Session {
  id          String   @id @default(uuid())
  formationId String
  dateDebut   DateTime
  dateFin     DateTime
  lieu        String?
  lienVisio   String?
  places      Int?
  createdAt   DateTime @default(now())

  formation Formation @relation(fields: [formationId], references: [id])

  @@schema("ir2f")
}

// ─── INSCRIPTIONS ────────────────────────────────────

model Inscription {
  id          String             @id @default(uuid())
  userId      String
  formationId String
  statut      StatutInscription  @default(EN_ATTENTE)
  origine     OrigineInscription @default(INTERNE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  formation Formation @relation(fields: [formationId], references: [id])

  @@unique([userId, formationId])
  @@schema("ir2f")
}

model DemandeInscription {
  id          String            @id @default(uuid())
  nom         String
  prenom      String
  email       String
  telephone   String?
  message     String?
  formationId String?
  userId      String?
  statut      StatutInscription @default(EN_ATTENTE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  formation Formation? @relation(fields: [formationId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])

  @@schema("ir2f")
}

// Demande envoyée depuis le formulaire "Je souhaite être contacté" de l'accueil —
// distincte de DemandeInscription qui déclenche un vrai workflow d'inscription
// (validation, création de compte). Ici : simple prise de contact, sans compte.
model DemandeContact {
  id         String   @id @default(uuid())
  thematique String
  nom        String
  prenom     String
  email      String
  telephone  String?
  message    String?
  createdAt  DateTime @default(now())

  @@schema("ir2f")
}

// ─── DOCUMENTS ───────────────────────────────────────

model Document {
  id          String            @id @default(uuid())
  nom         String
  url         String?
  storagePath String?
  taille      Int?
  mimeType    String?
  uploaderId  String
  formationId String?
  public      Boolean           @default(false)
  rolesRequis Role[]            @default([STAGIAIRE])
  categorie   DocumentCategorie @default(ADMINISTRATIF)
  createdAt   DateTime          @default(now())

  uploader   User        @relation(fields: [uploaderId], references: [id])
  formation  Formation?  @relation(fields: [formationId], references: [id])
  signatures Signature[]
  messages   Message[]

  @@schema("ir2f")
}

model Signature {
  id           String   @id @default(uuid())
  documentId   String
  userId       String
  signedAt     DateTime @default(now())
  signatureUrl String?
  consentText  String?
  ipAddress    String?
  userAgent    String?
  documentHash String?

  document Document @relation(fields: [documentId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([documentId, userId])
  @@schema("ir2f")
}

// ─── MESSAGERIE ──────────────────────────────────────

model Message {
  id           String   @id @default(uuid())
  expediteurId String
  sujet        String?
  contenu      String
  formationId  String?
  documentId   String?
  createdAt    DateTime @default(now())

  expediteur    User                  @relation("Expediteur", fields: [expediteurId], references: [id])
  destinataires MessageDestinataire[]
  formation     Formation?            @relation(fields: [formationId], references: [id])
  document      Document?             @relation(fields: [documentId], references: [id])

  @@schema("ir2f")
}

model MessageDestinataire {
  id        String    @id @default(uuid())
  messageId String
  userId    String
  lu        Boolean   @default(false)
  luAt      DateTime?

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@schema("ir2f")
}

// ─── COVOITURAGE ─────────────────────────────────────

model Covoiturage {
  id           String            @id @default(uuid())
  conducteurId String
  depart       String
  destination  String
  dateDepart   DateTime
  places       Int
  statut       StatutCovoiturage @default(OUVERT)
  commentaire  String?
  formationId  String?
  createdAt    DateTime          @default(now())

  conducteur User                  @relation("Conducteur", fields: [conducteurId], references: [id])
  passagers  CovoituragePassager[]
  formation  Formation?            @relation(fields: [formationId], references: [id])

  @@schema("ir2f")
}

model CovoituragePassager {
  id            String   @id @default(uuid())
  covoiturageId String
  userId        String
  createdAt     DateTime @default(now())

  covoiturage Covoiturage @relation(fields: [covoiturageId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([covoiturageId, userId])
  @@schema("ir2f")
}

// ─── ARTICLES / SITE PUBLIC ──────────────────────────

model Article {
  id        String              @id @default(uuid())
  titre     String
  slug      String              @unique
  contenu   String
  image     String?
  categorie CategorieFormation?
  publie    Boolean             @default(false)
  auteurId  String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  auteur User @relation(fields: [auteurId], references: [id])

  @@schema("ir2f")
}

// ─── CONTENU SITE PUBLIC (accueil / catalogue) ───────

// Icônes disponibles pour les cartes "Accompagnement Emploi" de l'accueil
enum IconeAccompagnement {
  FINANCEMENT
  GESTION
  FORMATION
  CONTACT
  DOCUMENT
  VALIDATION

  @@schema("ir2f")
}

model AccompagnementCard {
  id          String              @id @default(uuid())
  titre       String
  description String
  icone       IconeAccompagnement @default(FINANCEMENT)
  ordre       Int                 @default(0)
  actif       Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@schema("ir2f")
}

// Textes éditables de la page d'accueil (une seule ligne, id fixe "accueil")
model AccueilContenu {
  id                     String   @id @default("accueil")
  bandeauEmploiTitre     String   @default("Je souhaite créer un emploi dans mon club")
  bandeauEmploiActif     Boolean  @default(true)
  bandeauBouton1Label    String   @default("Je donne mes infos")
  bandeauBouton1Type     TypeLien @default(INTERNE)
  bandeauBouton1Url      String   @default("#contact")
  bandeauBouton2Label    String   @default("En savoir plus")
  bandeauBouton2Type     TypeLien @default(INTERNE)
  bandeauBouton2Url      String   @default("/emploi")
  accompagnementEyebrow  String   @default("IR2F vous accompagne")
  accompagnementTitre    String   @default("Accompagnement Emploi")
  contactTitre           String   @default("Je souhaite être contacté")
  contactSousTitre       String   @default("Un conseiller IR2F revient vers vous sous 48h.")
  updatedAt              DateTime @updatedAt

  @@schema("ir2f")
}

model StatCle {
  id        String   @id @default(uuid())
  valeur    String
  label     String
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("ir2f")
}

enum TransitionHero {
  FADE
  SLIDE_GAUCHE
  SLIDE_DROITE

  @@schema("ir2f")
}

enum AlignementHero {
  GAUCHE
  CENTRE
  DROITE

  @@schema("ir2f")
}

model HeroSlide {
  id             String         @id @default(uuid())
  badge          String?
  titre          String
  sousTitre      String?
  logoUrl        String?
  image          String
  ctaLabel       String?        @default("En savoir plus")
  formationId    String?
  youtubeUrl     String?
  alignement     AlignementHero @default(GAUCHE)
  overlayColor   String         @default("#0a162e")
  overlayOpacity Int            @default(60)
  transition     TransitionHero @default(FADE)
  dureeAffichage Int            @default(7)
  ordre          Int            @default(0)
  actif          Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  formation Formation? @relation(fields: [formationId], references: [id])

  @@schema("ir2f")
}

// Effet visuel appliqué aux images/vidéos des tuiles et onglets de la page
// "Nos Formations" (voir FormationTuile / FormationOnglet ci-dessous).
enum EffetVisuel {
  AUCUN
  FONDU
  ZOOM
  PARALLAXE
  NOIR_BLANC
  FLOU

  @@schema("ir2f")
}

// Les 4 tuiles cliquables en haut de la page "Nos Formations" (Éducateurs,
// Arbitres, Tout Terrain, DEV). Entièrement administrables : image, couleur
// de fond, opacité et effet visuel.
model FormationTuile {
  id              String             @id @default(uuid())
  categorie       CategorieFormation @unique
  label           String
  image           String?
  backgroundColor String             @default("#c9a84c")
  opacity         Int                @default(100)
  effetVisuel     EffetVisuel        @default(AUCUN)
  updatedAt       DateTime           @updatedAt

  @@schema("ir2f")
}

// Les onglets affichés dans le panneau déroulé d'une catégorie sur la page
// "Nos Formations" (ex : Présentation, Les différents parcours...).
enum FormationOngletCle {
  INFO
  PARCOURS
  CLUB
  EDU_PRESENTATION
  EDU_PRO
  EDU_BENEVOLE
  EDU_EQUIVALENCES

  @@schema("ir2f")
}

model FormationOnglet {
  id              String             @id @default(uuid())
  categorie       CategorieFormation
  onglet          FormationOngletCle
  titre           String?
  contenu         String?
  videoUrl        String?
  image           String?
  imageTaille     Int                @default(100)
  backgroundColor String             @default("#f5f7fb")
  opacity         Int                @default(100)
  effetVisuel     EffetVisuel        @default(AUCUN)
  updatedAt       DateTime           @updatedAt

  @@unique([categorie, onglet])
  @@schema("ir2f")
}

// ─── HERO PAR PAGE ───────────────────────────────────

// Pages statiques disposant d'un bandeau Hero (image de fond) éditable en
// admin. L'accueil a son propre système de Hero (HeroSlide, carrousel) et
// n'en fait pas partie ; les pages de détail (fiche formation, article) non
// plus, elles ont déjà leur propre visuel.
enum PageCle {
  FORMATIONS
  CONTACT
  EMPLOI
  ACTUALITES

  @@schema("ir2f")
}

model PageHero {
  id        String   @id @default(uuid())
  page      PageCle  @unique
  titre     String
  sousTitre String?
  image     String?
  updatedAt DateTime @updatedAt

  @@schema("ir2f")
}

// ─── EMPLOI ──────────────────────────────────────────

enum SectionEmploi {
  FINANCEMENTS
  GESTION_EMPLOI
  FORMATION_EMPLOYABILITE

  @@schema("ir2f")
}

enum TypeDocument {
  FICHIER
  LIEN_EXTERNE

  @@schema("ir2f")
}

model DocumentPasserelle {
  id        String        @id @default(uuid())
  titre     String
  url       String
  type      TypeDocument  @default(LIEN_EXTERNE)
  section   SectionEmploi
  ordre     Int           @default(0)
  actif     Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@schema("ir2f")
}

model Partenaire {
  id        String   @id @default(uuid())
  nom       String
  logoUrl   String?
  siteUrl   String?
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@schema("ir2f")
}

model Contact {
  id        String         @id @default(uuid())
  nom       String
  prenom    String?
  email     String?
  telephone String?
  poste     String?
  section   SectionEmploi?
  ordre     Int            @default(0)
  actif     Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@schema("ir2f")
}

model Video {
  id          String         @id @default(uuid())
  titre       String
  url         String
  description String?
  section     SectionEmploi?
  ordre       Int            @default(0)
  actif       Boolean        @default(true)
  createdAt   DateTime       @default(now())

  @@schema("ir2f")
}

model Webinaire {
  id          String   @id @default(uuid())
  titre       String
  description String?
  date        DateTime
  lien        String?
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("ir2f")
}
