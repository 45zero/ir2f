// IR2F — Plateforme de formation LGEF
// Schema dédié "ir2f", isolé de public/auth

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ir2f"]
}

// ─── ENUMS ───────────────────────────────────────────

enum Role {
  STAGIAIRE
  FORMATEUR
  ADMIN
  DIRECTION
  @@schema("ir2f")
}

enum StatutInscription {
  EN_ATTENTE
  VALIDEE
  REFUSEE
  @@schema("ir2f")
}

enum TypeFormation {
  PRESENTIEL
  VISIO
  ELEARNING
  MIXTE
  @@schema("ir2f")
}

enum StatutFormation {
  BROUILLON
  PUBLIEE
  ARCHIVEE
  @@schema("ir2f")
}

enum StatutCovoiturage {
  OUVERT
  COMPLET
  ANNULE
  @@schema("ir2f")
}

// ─── UTILISATEURS ────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nom       String
  prenom    String
  telephone String?
  role      Role     @default(STAGIAIRE)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inscriptions      Inscription[]
  documentsUpload   Document[]
  signatures        Signature[]
  messagesEnvoyes   Message[]        @relation("Expediteur")
  messagesRecus     MessageDestinataire[]
  covoituragesConduit Covoiturage[]  @relation("Conducteur")
  covoituragesPassager CovoituragePassager[]
  articles          Article[]
  demandesInscription DemandeInscription[]

  @@schema("ir2f")
}

// ─── FORMATIONS ──────────────────────────────────────

model Formation {
  id          String         @id @default(uuid())
  titre       String
  description String?
  type        TypeFormation
  statut      StatutFormation @default(BROUILLON)
  dureeHeures Int?
  prix        Float?
  places      Int?
  lienVisio   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  sessions     Session[]
  inscriptions Inscription[]
  demandes     DemandeInscription[]
  documents    Document[]

  @@schema("ir2f")
}

model Session {
  id          String    @id @default(uuid())
  formationId String
  dateDebut   DateTime
  dateFin     DateTime
  lieu        String?
  lienVisio   String?
  createdAt   DateTime  @default(now())

  formation   Formation @relation(fields: [formationId], references: [id])

  @@schema("ir2f")
}

// ─── INSCRIPTIONS ────────────────────────────────────

model Inscription {
  id          String           @id @default(uuid())
  userId      String
  formationId String
  statut      StatutInscription @default(EN_ATTENTE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  formation   Formation @relation(fields: [formationId], references: [id])

  @@unique([userId, formationId])
  @@schema("ir2f")
}

model DemandeInscription {
  id          String           @id @default(uuid())
  nom         String
  prenom      String
  email       String
  telephone   String?
  message     String?
  formationId String?
  userId      String?
  statut      StatutInscription @default(EN_ATTENTE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  formation   Formation? @relation(fields: [formationId], references: [id])
  user        User?      @relation(fields: [userId], references: [id])

  @@schema("ir2f")
}

// ─── DOCUMENTS ───────────────────────────────────────

model Document {
  id          String   @id @default(uuid())
  nom         String
  url         String
  taille      Int?
  mimeType    String?
  uploaderId  String
  formationId String?
  public      Boolean  @default(false)
  createdAt   DateTime @default(now())

  uploader    User       @relation(fields: [uploaderId], references: [id])
  formation   Formation? @relation(fields: [formationId], references: [id])
  signatures  Signature[]

  @@schema("ir2f")
}

model Signature {
  id         String   @id @default(uuid())
  documentId String
  userId     String
  signedAt   DateTime @default(now())
  signatureUrl String?

  document   Document @relation(fields: [documentId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([documentId, userId])
  @@schema("ir2f")
}

// ─── MESSAGERIE ──────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  expediteurId String
  sujet       String?
  contenu     String
  createdAt   DateTime @default(now())

  expediteur  User     @relation("Expediteur", fields: [expediteurId], references: [id])
  destinataires MessageDestinataire[]

  @@schema("ir2f")
}

model MessageDestinataire {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  lu        Boolean  @default(false)
  luAt      DateTime?

  message   Message  @relation(fields: [messageId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@schema("ir2f")
}

// ─── COVOITURAGE ─────────────────────────────────────

model Covoiturage {
  id           String            @id @default(uuid())
  conducteurId String
  depart       String
  destination  String
  dateDepart   DateTime
  places       Int
  statut       StatutCovoiturage @default(OUVERT)
  commentaire  String?
  createdAt    DateTime          @default(now())

  conducteur   User              @relation("Conducteur", fields: [conducteurId], references: [id])
  passagers    CovoituragePassager[]

  @@schema("ir2f")
}

model CovoituragePassager {
  id             String   @id @default(uuid())
  covoiturageId  String
  userId         String
  createdAt      DateTime @default(now())

  covoiturage    Covoiturage @relation(fields: [covoiturageId], references: [id])
  user           User        @relation(fields: [userId], references: [id])

  @@unique([covoiturageId, userId])
  @@schema("ir2f")
}

// ─── ARTICLES / SITE PUBLIC ──────────────────────────

model Article {
  id        String   @id @default(uuid())
  titre     String
  contenu   String
  publie    Boolean  @default(false)
  auteurId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auteur    User     @relation(fields: [auteurId], references: [id])

  @@schema("ir2f")
}
