// IR2F — Plateforme de formation LGEF
// Schema dédié "ir2f", isolé de public/auth

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ir2f"]
}

// ─── ENUMS ───────────────────────────────────────────

enum Role {
  STAGIAIRE
  FORMATEUR
  ADMIN
  DIRECTION

  @@schema("ir2f")
}

enum StatutInscription {
  EN_ATTENTE
  VALIDEE
  REFUSEE

  @@schema("ir2f")
}

enum TypeFormation {
  PRESENTIEL
  VISIO
  ELEARNING
  MIXTE

  @@schema("ir2f")
}

enum StatutFormation {
  BROUILLON
  PUBLIEE
  ARCHIVEE

  @@schema("ir2f")
}

enum CategorieFormation {
  EDUCATEUR
  ARBITRAGE
  TERRAIN
  CLUB
  DEV

  @@schema("ir2f")
}

enum Filiere {
  PROFESSIONNELLE
  BENEVOLE

  @@schema("ir2f")
}

// Groupe d'appartenance dans le diagramme "équivalences et passerelles"
// (page /formations, onglet Éducateur). Null = formation hors diagramme.
enum GroupeEquivalence {
  AF
  CFI
  DF
  CERTIF
  PRO_TOP
  PRO_MID
  PRO_BEF
  PRO_BMF
  PRO_MID2
  PRO_BOTTOM

  @@schema("ir2f")
}

enum VarianteNode {
  NAVY
  LIGHT
  RED
  OUTLINE

  @@schema("ir2f")
}

enum DocumentCategorie {
  ADMINISTRATIF
  PEDAGOGIQUE

  @@schema("ir2f")
}

enum StatutCovoiturage {
  OUVERT
  COMPLET
  ANNULE

  @@schema("ir2f")
}

// ─── UTILISATEURS ────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nom       String
  prenom    String
  telephone String?
  password  String?
  role      Role     @default(STAGIAIRE)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inscriptions         Inscription[]
  documentsUpload      Document[]
  signatures           Signature[]
  messagesEnvoyes      Message[]             @relation("Expediteur")
  messagesRecus        MessageDestinataire[]
  covoituragesConduit  Covoiturage[]         @relation("Conducteur")
  covoituragesPassager CovoituragePassager[]
  articles             Article[]
  demandesInscription  DemandeInscription[]
  formationsEnCharge   FormationFormateur[]

  @@schema("ir2f")
}

// ─── FORMATIONS ──────────────────────────────────────

model Formation {
  id            String          @id @default(uuid())
  slug          String          @unique
  titre         String
  description   String?
  type          TypeFormation
  statut        StatutFormation @default(BROUILLON)
  dureeHeures   Int?
  dureeLabel    String?
  modeLabel     String?
  lieu          String?
  prix          Float?
  places        Int?
  lienVisio     String?
  image         String?
  programme     Json?
  formateurNom  String?
  formateurRole String?
  ordre         Int             @default(0)

  categorie   CategorieFormation @default(EDUCATEUR)
  filiere     Filiere?
  cpfEligible Boolean            @default(false)

  // Diagramme "équivalences et passerelles" — null si hors diagramme
  groupeEquivalence GroupeEquivalence?
  varianteNode      VarianteNode?
  badgeNode         String?
  shortNode         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions     Session[]
  inscriptions Inscription[]
  demandes     DemandeInscription[]
  documents    Document[]
  heroSlides   HeroSlide[]
  formateurs   FormationFormateur[]
  messages     Message[]
  covoiturages Covoiturage[]

  @@schema("ir2f")
}

model FormationFormateur {
  id          String   @id @default(uuid())
  userId      String
  formationId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  formation Formation @relation(fields: [formationId], references: [id])

  @@unique([userId, formationId])
  @@schema("ir2f")
}

model Session {
  id          String   @id @default(uuid())
  formationId String
  dateDebut   DateTime
  dateFin     DateTime
  lieu        String?
  lienVisio   String?
  places      Int?
  createdAt   DateTime @default(now())

  formation Formation @relation(fields: [formationId], references: [id])

  @@schema("ir2f")
}

// ─── INSCRIPTIONS ────────────────────────────────────

model Inscription {
  id          String            @id @default(uuid())
  userId      String
  formationId String
  statut      StatutInscription @default(EN_ATTENTE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  formation Formation @relation(fields: [formationId], references: [id])

  @@unique([userId, formationId])
  @@schema("ir2f")
}

model DemandeInscription {
  id          String            @id @default(uuid())
  nom         String
  prenom      String
  email       String
  telephone   String?
  message     String?
  formationId String?
  userId      String?
  statut      StatutInscription @default(EN_ATTENTE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  formation Formation? @relation(fields: [formationId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])

  @@schema("ir2f")
}

// ─── DOCUMENTS ───────────────────────────────────────

model Document {
  id          String            @id @default(uuid())
  nom         String
  url         String?
  storagePath String?
  taille      Int?
  mimeType    String?
  uploaderId  String
  formationId String?
  public      Boolean           @default(false)
  rolesRequis Role[]            @default([STAGIAIRE])
  categorie   DocumentCategorie @default(ADMINISTRATIF)
  createdAt   DateTime          @default(now())

  uploader   User        @relation(fields: [uploaderId], references: [id])
  formation  Formation?  @relation(fields: [formationId], references: [id])
  signatures Signature[]
  messages   Message[]

  @@schema("ir2f")
}

model Signature {
  id           String   @id @default(uuid())
  documentId   String
  userId       String
  signedAt     DateTime @default(now())
  signatureUrl String?
  consentText  String?
  ipAddress    String?
  userAgent    String?
  documentHash String?

  document Document @relation(fields: [documentId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([documentId, userId])
  @@schema("ir2f")
}

// ─── MESSAGERIE ──────────────────────────────────────

model Message {
  id           String   @id @default(uuid())
  expediteurId String
  sujet        String?
  contenu      String
  formationId  String?
  documentId   String?
  createdAt    DateTime @default(now())

  expediteur    User                  @relation("Expediteur", fields: [expediteurId], references: [id])
  destinataires MessageDestinataire[]
  formation     Formation?            @relation(fields: [formationId], references: [id])
  document      Document?             @relation(fields: [documentId], references: [id])

  @@schema("ir2f")
}

model MessageDestinataire {
  id        String    @id @default(uuid())
  messageId String
  userId    String
  lu        Boolean   @default(false)
  luAt      DateTime?

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@schema("ir2f")
}

// ─── COVOITURAGE ─────────────────────────────────────

model Covoiturage {
  id           String            @id @default(uuid())
  conducteurId String
  depart       String
  destination  String
  dateDepart   DateTime
  places       Int
  statut       StatutCovoiturage @default(OUVERT)
  commentaire  String?
  formationId  String?
  createdAt    DateTime          @default(now())

  conducteur User                  @relation("Conducteur", fields: [conducteurId], references: [id])
  passagers  CovoituragePassager[]
  formation  Formation?            @relation(fields: [formationId], references: [id])

  @@schema("ir2f")
}

model CovoituragePassager {
  id            String   @id @default(uuid())
  covoiturageId String
  userId        String
  createdAt     DateTime @default(now())

  covoiturage Covoiturage @relation(fields: [covoiturageId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([covoiturageId, userId])
  @@schema("ir2f")
}

// ─── ARTICLES / SITE PUBLIC ──────────────────────────

model Article {
  id        String              @id @default(uuid())
  titre     String
  slug      String              @unique
  contenu   String
  image     String?
  categorie CategorieFormation?
  publie    Boolean             @default(false)
  auteurId  String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  auteur User @relation(fields: [auteurId], references: [id])

  @@schema("ir2f")
}

// ─── CONTENU SITE PUBLIC (accueil / catalogue) ───────

// Icônes disponibles pour les cartes "Accompagnement Emploi" de l'accueil
enum IconeAccompagnement {
  FINANCEMENT
  GESTION
  FORMATION
  CONTACT
  DOCUMENT
  VALIDATION

  @@schema("ir2f")
}

model AccompagnementCard {
  id          String              @id @default(uuid())
  titre       String
  description String
  icone       IconeAccompagnement @default(FINANCEMENT)
  ordre       Int                 @default(0)
  actif       Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@schema("ir2f")
}

// Textes éditables de la page d'accueil (une seule ligne, id fixe "accueil")
model AccueilContenu {
  id                    String   @id @default("accueil")
  bandeauEmploiTitre    String   @default("Je souhaite être accompagné sur l'emploi")
  accompagnementEyebrow String   @default("IR2F vous accompagne")
  accompagnementTitre   String   @default("Accompagnement Emploi")
  contactTitre          String   @default("Je souhaite être contacté")
  contactSousTitre      String   @default("Un conseiller IR2F revient vers vous sous 48h.")
  updatedAt             DateTime @updatedAt

  @@schema("ir2f")
}

model StatCle {
  id        String   @id @default(uuid())
  valeur    String
  label     String
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("ir2f")
}

enum TransitionHero {
  FADE
  SLIDE_GAUCHE
  SLIDE_DROITE

  @@schema("ir2f")
}

enum AlignementHero {
  GAUCHE
  CENTRE
  DROITE

  @@schema("ir2f")
}

model HeroSlide {
  id             String         @id @default(uuid())
  badge          String?
  titre          String
  sousTitre      String?
  logoUrl        String?
  image          String
  ctaLabel       String?        @default("En savoir plus")
  formationId    String?
  youtubeUrl     String?
  alignement     AlignementHero @default(GAUCHE)
  overlayColor   String         @default("#0a162e")
  overlayOpacity Int            @default(60)
  transition     TransitionHero @default(FADE)
  ordre          Int            @default(0)
  actif          Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  formation Formation? @relation(fields: [formationId], references: [id])

  @@schema("ir2f")
}

model CategorieInfo {
  id        String             @id @default(uuid())
  categorie CategorieFormation @unique
  titre     String
  corps     String
  updatedAt DateTime           @updatedAt

  @@schema("ir2f")
}

// ─── EMPLOI ──────────────────────────────────────────

enum SectionEmploi {
  FINANCEMENTS
  GESTION_EMPLOI
  FORMATION_EMPLOYABILITE

  @@schema("ir2f")
}

enum TypeDocument {
  FICHIER
  LIEN_EXTERNE

  @@schema("ir2f")
}

model DocumentPasserelle {
  id        String        @id @default(uuid())
  titre     String
  url       String
  type      TypeDocument  @default(LIEN_EXTERNE)
  section   SectionEmploi
  ordre     Int           @default(0)
  actif     Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@schema("ir2f")
}

model Partenaire {
  id        String   @id @default(uuid())
  nom       String
  logoUrl   String?
  siteUrl   String?
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@schema("ir2f")
}

model Contact {
  id        String         @id @default(uuid())
  nom       String
  prenom    String?
  email     String?
  telephone String?
  poste     String?
  section   SectionEmploi?
  ordre     Int            @default(0)
  actif     Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@schema("ir2f")
}

model Video {
  id          String         @id @default(uuid())
  titre       String
  url         String
  description String?
  section     SectionEmploi?
  ordre       Int            @default(0)
  actif       Boolean        @default(true)
  createdAt   DateTime       @default(now())

  @@schema("ir2f")
}

model Webinaire {
  id          String   @id @default(uuid())
  titre       String
  description String?
  date        DateTime
  lien        String?
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("ir2f")
}
